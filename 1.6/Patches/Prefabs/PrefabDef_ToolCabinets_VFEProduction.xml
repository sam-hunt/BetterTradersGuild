<?xml version="1.0" encoding="utf-8"?>
<Patch>
  <!--
    Better Traders Guild - VFE Production ToolCabinets Patch

    Vanilla ToolCabinet is not stuffable, but VFE Production patches it
    to be (adds stuffCategories). Without this patch, spawning a
    ToolCabinet from our PrefabDef works fine in vanilla. With VFE
    Production loaded, MakeThing requires a stuff parameter.

    This conditionally adds <stuff>Steel</stuff> to the ToolCabinet
    entries in BTG_ToolCabinets when VFE Production has made ToolCabinet
    stuffable.
  -->

  <Operation Class="PatchOperationConditional" MayRequire="VanillaExpanded.VFEProduction">
    <xpath>/Defs/ThingDef[defName="ToolCabinet"]/stuffCategories</xpath>
    <match Class="PatchOperationAdd">
      <xpath>Defs/PrefabDef[defName="BTG_ToolCabinets"]/things/ToolCabinet</xpath>
      <value>
        <stuff>Steel</stuff>
      </value>
    </match>
  </Operation>

</Patch>
