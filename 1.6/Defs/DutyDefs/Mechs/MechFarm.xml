<?xml version="1.0" encoding="utf-8"?>
<Defs>

  <!--
    Better Traders Guild - Agrihand farming duty.

    Priority order (each node only reached when the one above returns no job):
      1. Harvest mature food crops from in-range hydroponics basins (yield drops
         forbidden, since the mech is not the player faction).
      2. Haul that produce to the nearest in-range shelf (stays forbidden); if no
         shelf has room it is left on the floor, already forbidden.
      3. Sow the basin's crop (rice in the BTG greenhouse) into emptied basin cells.
      4. Return near the anchor point and dormant self-charge until a crop matures.

    Everything is confined to a moderate radius around the anchor AND the settlement
    structure footprint (see FarmArea). Used by LordJob_MechFarm.
  -->

  <DutyDef>
    <defName>BTG_MechFarm</defName>
    <thinkNode Class="ThinkNode_Priority">
      <subNodes>
        <li Class="BetterTradersGuild.AI.Mechs.JobGiver_BTGAgrihandHarvest" />
        <li Class="BetterTradersGuild.AI.Mechs.JobGiver_BTGAgrihandHaul" />
        <li Class="BetterTradersGuild.AI.Mechs.JobGiver_BTGAgrihandSow" />
        <li Class="BetterTradersGuild.AI.Mechs.JobGiver_BTGAgrihandStandby" />
      </subNodes>
    </thinkNode>
  </DutyDef>

</Defs>
