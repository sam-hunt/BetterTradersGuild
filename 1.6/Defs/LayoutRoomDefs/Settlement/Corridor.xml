<?xml version="1.0" encoding="utf-8"?>
<Defs>
  <!--
    Better Traders Guild - Custom Corridor Definitions

    Modern corridors with MetalTile flooring (not AncientTile).
    Provides clean, maintained aesthetic consistent with prosperous merchant settlement.
  -->

  <!-- Base corridor definition -->
  <LayoutRoomDef Name="BTG_Corridor">
    <defName>BTG_Corridor</defName>

    <!-- Custom worker with pre/post-fill hooks for blast door logging and airlock placement -->
    <roomContentsWorkerType>BetterTradersGuild.RoomContents.Corridor.RoomContents_Corridor</roomContentsWorkerType>

    <scatter>
      <!-- Occasional litter dropped by foot traffic passing through -->
      <Filth_Trash>
        <groupsPerHundredCells>0~1</groupsPerHundredCells>
        <itemsPerGroup>1~2</itemsPerGroup>
        <minGroups>0</minGroups>
      </Filth_Trash>
    </scatter>

    <parts>
      <BTG_Mech_Cleansweeper MayRequire="Ludeon.RimWorld.Biotech">1.0</BTG_Mech_Cleansweeper>
    </parts>

  </LayoutRoomDef>

  <!-- Defensive corridor variant with barricades -->
  <LayoutRoomDef ParentName="BTG_Corridor">
    <defName>BTG_CorridorDefense</defName>
    <prefabs>
      <!-- Defensive barricades along corridor -->
      <CorridorBarricade>
        <countPerHundredCells>1</countPerHundredCells>
        <ensureNoBlocks>false</ensureNoBlocks>
        <minMaxRange>1~2</minMaxRange>
      </CorridorBarricade>

      <!-- Barricades at corridor intersections -->
      <CorridorBarricadeIntersection>
        <countRange>0~1</countRange>
      </CorridorBarricadeIntersection>
    </prefabs>
  </LayoutRoomDef>
</Defs>
